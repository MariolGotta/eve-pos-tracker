# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eve_pos_tracker

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me
NEXTAUTH_URL=http://localhost:3000

# Discord OAuth App (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Your Discord user ID (get via Discord developer mode)
OWNER_DISCORD_ID=your_discord_user_id

# Secret to protect /api/cron/check-timers — generate with: openssl rand -hex 32
CRON_SECRET=change_me

# AES-256-GCM key for encrypting webhook URLs — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WEBHOOK_ENCRYPTION_KEY=change_me
