generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model AllowedGuild {
  guildId             String               @id
  name                String
  requiredRoleIds     String[]             @default([])
  addedAt             DateTime             @default(now())
  notificationConfigs NotificationConfig[]
}

enum Role {
  OWNER
  MEMBER
}

model User {
  id         String           @id @default(cuid())
  discordId  String           @unique
  username   String
  avatarUrl  String?
  role       Role             @default(MEMBER)
  createdAt  DateTime         @default(now())
  structures Structure[]
  timers     Timer[]
  events     StructureEvent[]
}

// ─── Eve Structures ──────────────────────────────────────────────────────────

enum StructureState {
  SHIELD           // Normal, full shields
  ARMOR_TIMER      // Shield stripped, waiting for armor window
  ARMOR_VULNERABLE // Armor can be attacked now
  HULL_TIMER       // Armor stripped, waiting for hull window
  HULL_VULNERABLE  // Hull can be attacked now
  DEAD             // Destroyed
}

model Structure {
  id             String         @id @default(cuid())
  system         String
  distanceFromSun Float
  name           String?
  corporation    String?
  notes          String?        @db.Text
  currentState        StructureState @default(SHIELD)
  vulnerableWindowEnd DateTime?      // set when entering ARMOR/HULL_VULNERABLE, cleared on next transition
  needsVerification   Boolean        @default(false) // flagged for someone to go check in-game
  deletedAt           DateTime?
  createdById         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  createdBy User             @relation(fields: [createdById], references: [id])
  timers    Timer[]
  events    StructureEvent[]

  @@index([system])
  @@index([currentState])
  @@index([system, currentState])
  @@index([deletedAt])
}

enum TimerKind {
  SHIELD_TO_ARMOR
  ARMOR_TO_HULL
}

enum TimerStatus {
  PENDING           // Timer is running
  EXPIRED_NOT_HIT   // Window opened, awaiting user action
  PROGRESSED        // User confirmed next state was hit
  REGENERATED       // POS repaired, back to shield
  CANCELLED         // Entry error, removed
}

model Timer {
  id          String      @id @default(cuid())
  structureId String
  kind        TimerKind
  startedAt   DateTime
  expiresAt   DateTime
  status      TimerStatus @default(PENDING)
  notifiedAt  DateTime?   // last notification sent (avoids duplicate webhooks)
  createdById String
  createdAt   DateTime    @default(now())

  structure Structure @relation(fields: [structureId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([expiresAt])
  @@index([status])
  @@index([structureId, status])
}

model StructureEvent {
  id          String   @id @default(cuid())
  structureId String
  userId      String
  action      String   // SHIELD_DOWN, ARMOR_DOWN, HULL_DOWN, REGENERATED, MARKED_DEAD, EDITED, TIMER_EXPIRED, CANCELLED
  payload     Json?
  createdAt   DateTime @default(now())

  structure Structure @relation(fields: [structureId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([structureId])
  @@index([createdAt])
}

model NotificationConfig {
  id                   String       @id @default(cuid())
  guildId              String
  webhookUrl           String       @db.Text // stored encrypted
  notifyMinutesBefore  Int[]        @default([60, 15])
  enabled              Boolean      @default(true)

  guild AllowedGuild @relation(fields: [guildId], references: [guildId])

  @@unique([guildId])
}
