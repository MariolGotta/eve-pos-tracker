generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model AllowedGuild {
  guildId             String               @id
  name                String
  requiredRoleIds     String[]             @default([])
  addedAt             DateTime             @default(now())
  notificationConfigs NotificationConfig[]
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id          String           @id @default(cuid())
  discordId   String           @unique
  username    String
  displayName String?          // guild nickname or global display name, updated on each login
  avatarUrl   String?
  role        Role             @default(MEMBER)
  createdAt   DateTime         @default(now())
  structures       Structure[]
  timers           Timer[]
  events           StructureEvent[]
  timerAttendances TimerAttendee[]
  killmailEvents   KillmailEvent[]
}

// ─── Eve Structures ──────────────────────────────────────────────────────────

enum StructureKind {
  POS
  CITADEL
}

enum StructureState {
  SHIELD           // Normal, full shields
  ARMOR_TIMER      // Shield stripped, waiting for armor window
  ARMOR_VULNERABLE // Armor can be attacked now
  HULL_TIMER       // Armor stripped, waiting for hull window
  HULL_VULNERABLE  // Hull can be attacked now
  DEAD             // Destroyed
}

model Structure {
  id              String         @id @default(cuid())
  kind            StructureKind  @default(POS)
  system          String
  distanceFromSun Float
  name            String?
  corporation     String?
  notes          String?        @db.Text
  currentState        StructureState @default(SHIELD)
  vulnerableWindowEnd DateTime?      // set when entering ARMOR/HULL_VULNERABLE, cleared on next transition
  needsVerification   Boolean        @default(false) // flagged for someone to go check in-game
  deletedAt           DateTime?
  createdById         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  createdBy User             @relation(fields: [createdById], references: [id])
  timers    Timer[]
  events    StructureEvent[]

  @@index([system])
  @@index([currentState])
  @@index([system, currentState])
  @@index([deletedAt])
}

enum TimerKind {
  SHIELD_TO_ARMOR
  ARMOR_TO_HULL
}

enum TimerStatus {
  PENDING           // Timer is running
  EXPIRED_NOT_HIT   // Window opened, awaiting user action
  PROGRESSED        // User confirmed next state was hit
  REGENERATED       // POS repaired, back to shield
  CANCELLED         // Entry error, removed
}

model Timer {
  id          String      @id @default(cuid())
  structureId String
  kind        TimerKind
  startedAt   DateTime
  expiresAt   DateTime
  status      TimerStatus @default(PENDING)
  notifiedAt  DateTime?   // last notification sent (avoids duplicate webhooks)
  createdById String
  createdAt   DateTime    @default(now())

  structure  Structure       @relation(fields: [structureId], references: [id])
  createdBy  User            @relation(fields: [createdById], references: [id])
  attendees  TimerAttendee[]

  @@index([expiresAt])
  @@index([status])
  @@index([structureId, status])
}

model TimerAttendee {
  id        String   @id @default(cuid())
  timerId   String
  userId    String
  createdAt DateTime @default(now())

  timer Timer @relation(fields: [timerId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([timerId, userId])
  @@index([timerId])
}

model StructureEvent {
  id          String   @id @default(cuid())
  structureId String
  userId      String
  action      String   // SHIELD_DOWN, ARMOR_DOWN, HULL_DOWN, REGENERATED, MARKED_DEAD, EDITED, TIMER_EXPIRED, CANCELLED
  payload     Json?
  createdAt   DateTime @default(now())

  structure Structure @relation(fields: [structureId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([structureId])
  @@index([createdAt])
}

model NotificationConfig {
  id                   String       @id @default(cuid())
  guildId              String
  webhookUrls          String[]     // each entry stored encrypted
  notifyMinutesBefore  Int[]        @default([60, 15])
  enabled              Boolean      @default(true)

  guild AllowedGuild @relation(fields: [guildId], references: [guildId])

  @@unique([guildId])
}

// ─── PPK (Pay Per Kill) ───────────────────────────────────────────────────────

enum ShipType {
  SUBCAP
  POS
  CAPITAL
}

enum KillmailStatus {
  PENDING  // aguardando prints adicionais (dano < 98%)
  COMPLETE // todos participantes registrados, saldos calculados
}

model Killmail {
  id                   String         @id           // ID do jogo (ex: "11920642")
  reportTitle          String                        // "RELATÓRIO DE ABATE" ou "killmail"
  timestampUtc         DateTime
  system               String
  region               String?
  totalDamage          Int
  iskValue             BigInt                        // ISK do kill
  shipType             ShipType       @default(SUBCAP)
  victimPilot          String
  victimCorpTag        String
  victimShip           String
  participantsTotal    Int?                          // do cabeçalho "Participantes [N]"
  status               KillmailStatus @default(PENDING)
  damageCoverage       Float          @default(0)   // soma de damagePct atual (0-100)
  sourceGuildId        String?
  submittedByDiscordId String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  attackers KillmailAttacker[]
  events    KillmailEvent[]

  @@index([status])
  @@index([timestampUtc])
  @@index([victimCorpTag])
}

model KillmailAttacker {
  id         String  @id @default(cuid())
  killmailId String
  pilot      String
  corpTag    String
  ship       String
  damage     Int
  damagePct  Float
  finalBlow  Boolean @default(false)
  topDamage  Boolean @default(false)
  iskEarned  BigInt? // calculado pela pipeline PPK após COMPLETE

  killmail Killmail @relation(fields: [killmailId], references: [id], onDelete: Cascade)

  @@unique([killmailId, pilot])
  @@index([killmailId])
  @@index([pilot])
  @@index([corpTag])
}

model Player {
  id          String   @id @default(cuid())
  pilot       String   @unique
  corpTag     String?                   // última corp conhecida
  totalEarned BigInt   @default(0)
  totalPaid   BigInt   @default(0)
  remaining   BigInt   @default(0)      // totalEarned - totalPaid (cache recalculado)
  updatedAt   DateTime @updatedAt

  payments Payment[]

  @@index([remaining])
  @@index([pilot])
}

model Payment {
  id              String   @id @default(cuid())
  playerId        String
  iskAmount       BigInt
  notes           String?
  paidByDiscordId String
  createdAt       DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId])
}

model PpkCorporation {
  id        String   @id @default(cuid())
  corpTag   String   @unique              // ex: "FLBR", "W4VE"
  fullName  String?
  eligible  Boolean  @default(true)       // se recebe PPK ("is bot5?")
  createdAt DateTime @default(now())
}

model KillmailEvent {
  id         String   @id @default(cuid())
  killmailId String
  userId     String?                // null when triggered by bot
  action     String                 // CREATED, EDITED, ATTACKER_ADDED, ATTACKER_EDITED, ATTACKER_REMOVED, REPROCESSED, DELETED
  payload    Json?
  createdAt  DateTime @default(now())

  killmail   Killmail @relation(fields: [killmailId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([killmailId])
  @@index([createdAt])
}

model PpkConfig {
  id                 Int      @id @default(1) // singleton
  subcapMultiplier   Float    @default(1.0)   // BountyRewards!B2
  posFixedIsk        BigInt   @default(0)     // BountyRewards!B1 (ISK fixo por POS)
  capitalFixedIsk    BigInt   @default(0)     // BountyRewards!B3
  bot5Coefficient    Float    @default(1.0)   // BountyRewards!A7 (corp elegível)
  nonBot5Coefficient Float    @default(0.5)   // BountyRewards!B7 (corp não elegível)
  subcapCapIsk       BigInt   @default(15000000000) // cap de 15B ISK para subcap
  updatedAt          DateTime @updatedAt
}
